# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Python files
[*.py]
indent_size = 4
max_line_length = 100

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 4

# Dockerfiles
[Dockerfile]
indent_size = 4

# JSON
[*.json]
indent_size = 2

# TOML
[*.toml]
indent_size = 4

# Makefile
[Makefile]
indent_style = tab
indent_size = 4

# Git files
[.gitignore]
indent_style = unset
indent_size = unset
